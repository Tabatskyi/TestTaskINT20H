# ------------------------------
# Database Credentials
# ------------------------------

# Orders DB
ORDER_DB_USER=
ORDER_DB_PASSWORD=

# Admins DB
ADMIN_DB_USER=
ADMIN_DB_PASSWORD=

# ------------------------------
# Frontend Settings
# ------------------------------
# Not needed for Docker (nginx proxies /api to backend).
# Only set for local dev without Docker, e.g. http://localhost:5000
VITE_API_URL=

# ------------------------------
# Backend Settings (Overrides appsettings.json)
# ------------------------------
# Hosts and CORS
ALLOWED_HOSTS=
CORS_ALLOWED_ORIGINS_0=
CORS_ALLOWED_ORIGINS_1=

# Security (JWT requires a long, complex key - at least 32 chars)
JWT_KEY=

# App Initialization
DEFAULT_ADMIN_USER=
DEFAULT_ADMIN_PASSWORD=