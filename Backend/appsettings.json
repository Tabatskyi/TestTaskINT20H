{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "AllowedHosts": "",                     // Override with .env
    "Cors": {
        "AllowedOrigins": []                // Override with .env
    },
    "Jwt": {
        "Key": "",                          // Override with .env
        "Issuer": "WellnessKitAPI",
        "Audience": "WellnessKitAPI",
        "ExpiryMinutes": 60
    },
    "DefaultAdmin": {
        "Username": "admin",
        "Password": ""                      // Override with .env
    },
    "Kestrel": {
        "Endpoints": {
            "Http": {
                "Url": "http://+:5000"
            }
        }
    },
    "LaunchBrowser": false,
    "ConnectionStrings": {
        "OrdersConnection": "",             // Overrided by Docker Compose
        "AdminsConnection": ""              // Overrided by Docker Compose
    }
}